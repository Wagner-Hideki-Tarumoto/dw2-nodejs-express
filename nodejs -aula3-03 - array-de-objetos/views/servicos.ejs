<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Servicos</title>
</head>
<body>
    <h1>Servicos</h1>
    <hr>
    <h3>Confira nosssos servicos</h3>
    <!--Exibindo a array de objetos em uma tabela com forEach-->

    <table border="1">
    <tr>
<th>Servicos</th>
<th>Descricao</th>
<th>Preco</th>

    </tr>
    <% servicos.forEach(function(servico){%>
<tr>
<td><%= servico.servico%></td>
<td><%= servico.descricao%></td>
<td><%= servico.preco%></td>
</tr>

    <%})%>
    </table>
</body>
    <p><a href="/"Voltar para a pagina inicial></a></p>
</html>